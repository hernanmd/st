#!/usr/bin/env bash
#
# runSmalltalkTests - Run all tests for the smalltalk CLI
#
# Lives in tests/. Usage: ./tests/runSmalltalkTests [options] [test-files...]
#
# Options:
#   -v, --verbose    Show verbose output
#   -f, --filter     Filter tests by name pattern
#   -h, --help       Show this help message
#
# Exit codes:
#   0 - All tests passed
#   1 - One or more tests failed
#
set -Eeuo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
# This script lives in tests/, so .bats files are alongside it by default.
# SCRIPT_ROOT (optional) points at a project root whose tests/ dir should be used.
if [[ -n "${SCRIPT_ROOT:-}" ]]; then
    TESTS_DIR="${SCRIPT_ROOT}/tests"
else
    TESTS_DIR="$SCRIPT_DIR"
fi

# ANSI colors
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m' # No Color

printf "${BLUE}========================================${NC}\n"
printf "${BLUE}Smalltalk CLI Test Suite${NC}\n"
printf "${BLUE}========================================${NC}\n"
printf "\n"

# Check if bats is installed
if ! command -v bats &> /dev/null; then
    printf "${YELLOW}Warning: bats is not installed${NC}\n"
    printf "Install bats to run tests:\n"
    printf "  brew install bats-core\n"
    printf "\n"
fi

# Parse arguments
VERBOSE=0
FILTER=""
TEST_FILES=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -v | --verbose)
            VERBOSE=1
            shift
            ;;
        -f | --filter)
            FILTER="$2"
            shift 2
            ;;
        -h | --help)
            printf "Usage: %s [options] [test-files...]\n" "$0"
            printf "\n"
            printf "Options:\n"
            printf "  -v, --verbose    Show verbose output\n"
            printf "  -f, --filter     Filter tests by name pattern\n"
            printf "  -h, --help       Show this help message\n"
            printf "\n"
            printf "Examples:\n"
            printf "  %s                    # Run all tests\n" "$0"
            printf "  %s test-*.bats        # Run specific test files\n" "$0"
            printf "  %s -f pharo           # Run tests matching 'pharo'\n" "$0"
            exit 0
            ;;
        --)
            shift
            break
            ;;
        *)
            TEST_FILES+=("$1")
            shift
            ;;
    esac
done

# Default to all test files
if [[ ${#TEST_FILES[@]} -eq 0 ]]; then
    while IFS= read -r f; do
        TEST_FILES+=("$f")
    done < <(find "${TESTS_DIR}" -name '*.bats' -type f 2> /dev/null || true)
fi

# Count tests
TOTAL_FILES=0
for f in "${TEST_FILES[@]}"; do
    if [[ -f "$f" ]]; then
        ((TOTAL_FILES++)) || true
    fi
done

printf "Running %d test file(s)...\n" "$TOTAL_FILES"
printf "\n"

# Track results
TOTAL_PASSED=0
TOTAL_FAILED=0
FAILED_TESTS=()

# Run tests
for test_file in "${TEST_FILES[@]}"; do
    if [[ ! -f "$test_file" ]]; then
        printf "${YELLOW}Warning: Test file not found: %s${NC}\n" "$test_file"
        continue
    fi

    test_name="$(basename -- "$test_file")"
    printf "${BLUE}Running %s...${NC}\n" "$test_name"

    # Build command
    cmd="bats \"$test_file\""
    if [[ -n "$FILTER" ]]; then
        cmd="$cmd --filter \"$FILTER\""
    fi

    # Run tests
    output="$(eval -- "$cmd" 2>&1)" || true
    exit_code=$?

    # Count passed/failed (grep -c prints 0 and exits 1 on no matches; `|| true`
    # avoids the "0\n0" double-count that broke the arithmetic below).
    passed="$(printf '%s' "$output" | grep -c '^ok ' || true)"
                                                                passed="${passed:-0}"
    failed="$(printf '%s' "$output" | grep -c '^not ok ' || true)"
                                                                    failed="${failed:-0}"

    TOTAL_PASSED=$((TOTAL_PASSED + passed))
    TOTAL_FAILED=$((TOTAL_FAILED + failed))

    if [[ "$failed" -gt 0 ]]; then
        FAILED_TESTS+=("$test_file")
    fi

    # Show summary line
    if [[ "$failed" -eq 0 ]]; then
        printf "${GREEN}✓ %s tests passed${NC}\n" "$passed"
    else
        printf "${RED}✗ %s test(s) failed${NC}\n" "$failed"
        if [[ "$VERBOSE" -eq 1 ]]; then
            printf '%s' "$output" | grep '^not ok '
        fi
    fi
    printf "\n"
done

# Summary
printf "${BLUE}========================================${NC}\n"
printf "${BLUE}Test Summary${NC}\n"
printf "${BLUE}========================================${NC}\n"
printf "\n"
printf "Total files: %d\n" "$TOTAL_FILES"
printf "Total tests: %d\n" $((TOTAL_PASSED + TOTAL_FAILED))
printf "${GREEN}Passed: %d${NC}\n" "$TOTAL_PASSED"
if [[ "$TOTAL_FAILED" -gt 0 ]]; then
    printf "${RED}Failed: %d${NC}\n" "$TOTAL_FAILED"
    printf "\n"
    printf "${RED}Failed test files:${NC}\n"
    for f in "${FAILED_TESTS[@]}"; do
        printf "  - %s\n" "$f"
    done
    printf "\n"
    exit 1
else
    printf "${GREEN}All tests passed!${NC}\n"
    printf "\n"
    exit 0
fi
