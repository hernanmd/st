#!/usr/bin/env bash
#
# runSmalltalkTests - Run all tests for the smalltalk CLI
#
set -u
set -o pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}" && pwd)"
TESTS_DIR="${PROJECT_ROOT}/tests"

# ANSI colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}Smalltalk CLI Test Suite${NC}"
echo -e "${BLUE}========================================${NC}"
echo ""

# Check if bats is installed
if ! command -v bats &> /dev/null; then
    echo -e "${YELLOW}Warning: bats is not installed${NC}"
    echo "Install bats to run tests:"
    echo "  brew install bats-core"
    echo ""
fi

# Parse arguments
VERBOSE=0
FILTER=""
TEST_FILES=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -v|--verbose)
            VERBOSE=1
            shift
            ;;
        -f|--filter)
            FILTER="$2"
            shift 2
            ;;
        -h|--help)
            echo "Usage: $0 [options] [test-files...]"
            echo ""
            echo "Options:"
            echo "  -v, --verbose    Show verbose output"
            echo "  -f, --filter     Filter tests by name pattern"
            echo "  -h, --help       Show this help message"
            echo ""
            echo "Examples:"
            echo "  $0                    # Run all tests"
            echo "  $0 tests/test-*.bats  # Run specific test files"
            echo "  $0 -f pharo           # Run tests matching 'pharo'"
            exit 0
            ;;
        *)
            TEST_FILES+=("$1")
            shift
            ;;
    esac
done

# Default to all test files
if [[ ${#TEST_FILES[@]} -eq 0 ]]; then
    TEST_FILES=("${TESTS_DIR}"/*.bats)
fi

# Count tests
TOTAL_FILES=0
for f in "${TEST_FILES[@]}"; do
    if [[ -f "$f" ]]; then
        ((TOTAL_FILES++))
    fi
done

echo "Running $TOTAL_FILES test file(s)..."
echo ""

# Track results
TOTAL_PASSED=0
TOTAL_FAILED=0
FAILED_TESTS=()

# Run tests
for test_file in "${TEST_FILES[@]}"; do
    if [[ ! -f "$test_file" ]]; then
        echo -e "${YELLOW}Warning: Test file not found: $test_file${NC}"
        continue
    fi

    test_name=$(basename "$test_file")
    echo -e "${BLUE}Running $test_name...${NC}"

    # Build command
    cmd="bats \"$test_file\""
    if [[ -n "$FILTER" ]]; then
        cmd="$cmd --filter \"$FILTER\""
    fi

    # Run tests
    if [[ "$VERBOSE" -eq 1 ]]; then
        output=$($cmd 2>&1)
    else
        output=$($cmd 2>&1)
    fi
    exit_code=$?

    # Count passed/failed
    passed=$(echo "$output" | grep -c "^ok " || echo "0")
    failed=$(echo "$output" | grep -c "^not ok " || echo "0")

    TOTAL_PASSED=$((TOTAL_PASSED + passed))
    TOTAL_FAILED=$((TOTAL_FAILED + failed))

    if [[ "$failed" -gt 0 ]]; then
        FAILED_TESTS+=("$test_file")
    fi

    # Show summary line
    if [[ "$failed" -eq 0 ]]; then
        echo -e "${GREEN}✓ $passed tests passed${NC}"
    else
        echo -e "${RED}✗ $failed test(s) failed${NC}"
        if [[ "$VERBOSE" -eq 1 ]]; then
            echo "$output" | grep "^not ok "
        fi
    fi
    echo ""
done

# Summary
echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}Test Summary${NC}"
echo -e "${BLUE}========================================${NC}"
echo ""
echo -e "Total files: ${TOTAL_FILES}"
echo -e "Total tests: $((TOTAL_PASSED + TOTAL_FAILED))"
echo -e "${GREEN}Passed: $TOTAL_PASSED${NC}"
if [[ "$TOTAL_FAILED" -gt 0 ]]; then
    echo -e "${RED}Failed: $TOTAL_FAILED${NC}"
    echo ""
    echo -e "${RED}Failed test files:${NC}"
    for f in "${FAILED_TESTS[@]}"; do
        echo "  - $f"
    done
    echo ""
    exit 1
else
    echo -e "${GREEN}All tests passed!${NC}"
    echo ""
    exit 0
fi
