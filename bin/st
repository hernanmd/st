#!/usr/bin/env bash
#
# st - A unified CLI for Smalltalk implementations
#
# Usage: st [--debug] [--quiet] [--verbose] <implementation> <command> [options]
#
# Implementations: pharo, cuis, gt, squeak, gnu, lst, ls4
# Commands: install, run, eval, search, list, update, clean, clean-artifacts, help
#
# Exit codes:
#   0 - Success
#   1 - General error / invalid arguments
#   2 - Command not supported by implementation
#
# See: https://github.com/hernanmd/st
#
set -Euo pipefail

# Prevent word splitting on spaces in variable expansions
IFS=$'\n\t'

# Handle debug flag early before any other processing
if [[ $# -gt 0 ]] && ([[ "$1" == "-x" ]] || [[ "$1" == "--debug" ]]); then
    export DEBUG=1
    set -x
    shift
fi

# Handle quiet flag early before any other processing
if [[ $# -gt 0 ]] && ([[ "$1" == "-q" ]] || [[ "$1" == "--quiet" ]]); then
    export QUIET=1
    shift
fi

# Handle verbose flag early before any other processing
if [[ $# -gt 0 ]] && ([[ "$1" == "-v" ]] || [[ "$1" == "--verbose" ]]); then
    export VERBOSE=1
    shift
fi

# Handle yes flag early before any other processing (auto-confirm prompts,
# e.g. the GNU Smalltalk sudo install confirmation).
if [[ $# -gt 0 ]] && ([[ "$1" == "-y" ]] || [[ "$1" == "--yes" ]]); then
    export SMALLTALK_YES=1
    shift
fi

# Get the directory where this script is located (resolves symlinks)
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
LIBEXEC_DIR="${SCRIPT_DIR}/../libexec"

# Source common utilities
# shellcheck source=libexec/smalltalk-common.sh
source "${LIBEXEC_DIR}/smalltalk-common.sh"

# Print usage information
print_usage() {
    printf '%s\n' \
        $'\033[1mUSAGE\033[0m' \
        $'  st [--debug] [--quiet] [--verbose] <implementation> <command> [options]' \
        '' \
        $'\033[1mGLOBAL OPTIONS\033[0m' \
        $'  --debug, -x         Enable debug mode (set -x tracing)' \
        $'  --quiet, -q         Suppress all output (no colors, no INFO/WARN/SUCCESS/ERROR messages)' \
        $'  --verbose, -v       Show detailed output (file listings during extraction)' \
        $'  --yes, -y           Auto-confirm prompts (e.g. GNU Smalltalk sudo install)' \
        $'  --list, -l          List available Smalltalk implementations' \
        $'  --version           Show version information' \
        $'  --help, -h          Show this help message' \
        '' \
        $'\033[1mIMPLEMENTATIONS\033[0m' \
        $'  pharo       Pharo Smalltalk (https://pharo.org)' \
        $'  cuis        Cuis Smalltalk (https://cuis.st)' \
        $'  gt          Glamorous Toolkit (https://gtoolkit.com)' \
        $'  squeak      Squeak Smalltalk (https://squeak.org)' \
        $'  gnu         GNU Smalltalk (https://gnu.org/software/smalltalk)' \
        $'  lst         Little Smalltalk (https://codeberg.org/suetanvil/lst3r)' \
        $'  ls4         Little Smalltalk v4 (https://github.com/kyle-github/littlesmalltalk)' \
        '' \
        $'\033[1mCOMMANDS\033[0m' \
        $'  install          Install the Smalltalk implementation or a package' \
        $'  run              Launch the Smalltalk UI/environment' \
        $'  eval             Evaluate Smalltalk code (headless)' \
        $'  load             Load and execute a .st source file' \
        $'  save             Save the Smalltalk image' \
        $'  metacello        Install a Metacello baseline/configuration' \
        $'  search           Search for packages' \
        $'  list             List available packages' \
        $'  update           Update package cache' \
        $'  clean            Clean cache directory' \
        $'  clean-artifacts  Clean installed Smalltalk artifacts' \
        $'  help             Show help for a specific implementation or command' \
        '' \
        $'\033[1mEXAMPLES\033[0m' \
        $'  st pharo install                    # Install Pharo' \
        $'  st pharo install SomePackage        # Install a Pharo package' \
        $'  st pharo install -d ~/my-pharo      # Install to specific directory' \
        $'  st -x pharo install                 # Install with debug output' \
        $'  st -q pharo install                 # Install with no output' \
        $'  st pharo run                        # Launch Pharo UI' \
        $'  st pharo eval \'1+2\'                # Evaluate Smalltalk code' \
        $'  st pharo load script.st             # Load a .st file' \
        $'  st pharo metacello \'BaselineOf...\'  # Load Metacello baseline' \
        $'  st pharo save myimage               # Save the image' \
        $'  st gt install                       # Install Glamorous Toolkit' \
        $'  st gt eval \'42 inspect\'            # Evaluate in GT' \
        $'  st squeak install                   # Install Squeak' \
        $'  st -v squeak install                # Install with verbose output' \
        $'  st gnu install                      # Install GNU Smalltalk (prompts for sudo)' \
        $'  st -y gnu install                   # Install GNU Smalltalk, auto-confirm sudo' \
        '' \
        "For more information about a specific implementation:" \
        $'  st pharo help' \
        $'  st gt help' \
        $'  st cuis help'
}

# Print available implementations
print_implementations() {
    printf '%-12s %s\n' "pharo"  "Modern, full-featured Smalltalk environment"
    printf '%-12s %s\n' "cuis"   "Compact, portable Smalltalk distribution"
    printf '%-12s %s\n' "gt"     "Multi-language moldable development environment"
    printf '%-12s %s\n' "squeak" "Classic open-source Smalltalk platform"
    printf '%-12s %s\n' "gnu"    "Traditional Smalltalk-80 command-line interpreter"
    printf '%-12s %s\n' "lst"    "Minimal Smalltalk for learning and experimentation"
    printf '%-12s %s\n' "ls4"    "Lightweight Smalltalk v4 with bytecode compiler"
}

# Print version information
print_version() {
    local version
    version="$(cat "${SCRIPT_DIR}/../VERSION" 2> /dev/null || echo "1.0.0")"
    printf "st version %s\n" "$version"
    printf "A unified CLI for Smalltalk implementations\n"
}

# Main entry point
main() {
    local impl="${1:-}"
    local cmd="${2:-}"

    # Normalize command name (replace hyphens with underscores)
    cmd="${cmd//-/_}"

    # Handle global commands
    case "$impl" in
        clean_artifacts)
            local target="${3:-}"
            if [[ -z "$target" ]]; then
                clean_all_artifacts
            elif [[ "$target" == "pharo" || "$target" == "gt" || "$target" == "cuis" || "$target" == "squeak" || "$target" == "gnu" || "$target" == "lst" || "$target" == "ls4" ]]; then
                # shellcheck source=libexec/smalltalk-common.sh
                source "${LIBEXEC_DIR}/smalltalk-${target}.sh"
                "smalltalk_${target}_clean_artifacts"
            else
                printf "Error: Unknown implementation '%s'\n" "$target" >&2
                printf "Run 'st clean_artifacts' without arguments to clean all artifacts.\n" >&2
                exit 1
            fi
            exit 0
            ;;
        --list | -l | list)
            print_implementations
            exit 0
            ;;
        help | --help | -h)
            print_usage
            exit 0
            ;;
        --version | -V | version)
            print_version
            exit 0
            ;;
        "")
            print_usage >&2
            exit 1
            ;;
        *)
            ;;
    esac

    # Validate implementation
    case "$impl" in
        pharo | cuis | gt | squeak | gnu | lst | ls4)
            ;;
        *)
            printf "Error: Unknown implementation '%s'\n" "$impl" >&2
            printf "Run 'st' without arguments to see available implementations.\n" >&2
            exit 1
            ;;
    esac

    if [[ -z "$cmd" ]]; then
        printf "Error: No command specified for '%s'\n" "$impl" >&2
        printf "Run 'st %s help' for available commands.\n" "$impl" >&2
        exit 1
    fi

    # Source the implementation-specific script
    # shellcheck source=libexec/smalltalk-common.sh
    source "${LIBEXEC_DIR}/smalltalk-${impl}.sh"

    # Execute the command via dynamic dispatch
    local func_name="smalltalk_${impl}_${cmd}"
    if declare -f "$func_name" > /dev/null 2>&1; then
        "$func_name" "${@:3}"
    else
        printf "Error: Command '%s' is not supported by '%s'\n" "$cmd" "$impl" >&2
        printf "Run 'st %s help' for available commands.\n" "$impl" >&2
        exit 2
    fi
}

main "$@"
